# ── Required ──────────────────────────────────────────────────────────────────
# Your Discord bot token (from discord.com/developers/applications)
DISCORD_TOKEN=your_discord_token_here

# PostgreSQL connection string — Railway provides this automatically when you
# add a Postgres database to your project (copy from the "Connect" tab).
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Optional ──────────────────────────────────────────────────────────────────
# (Add any other env vars your bot uses here)
